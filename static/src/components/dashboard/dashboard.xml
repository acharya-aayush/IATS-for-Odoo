<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="iats_recruitment.DashboardCard" owl="1">
        <div class="o_iats_dashboard_wrap w-100 h-100 d-flex text-dark">
            
            <!-- Left Sidebar: Job Selections -->
            <aside class="iats-sidebar d-flex flex-column h-100 shadow-sm z-1">
                <div class="p-3 border-bottom bg-white d-flex align-items-center gap-2">
                    <div class="bg-primary text-white rounded p-2 d-flex align-items-center justify-content-center">
                        <i class="fa fa-briefcase"></i>
                    </div>
                    <div>
                        <h6 class="m-0 fw-bold">Active Jobs</h6>
                        <small class="text-muted">Select a position</small>
                    </div>
                </div>
                <div class="overflow-auto flex-grow-1 p-2 bg-light">
                    <t t-foreach="state.jobs" t-as="job" t-key="job.id">
                        <button class="w-100 text-start btn mb-1 rounded-3 px-3 py-2 text-truncate iats-job-btn line-height-sm"
                                t-attf-class="#{state.activeJobId === job.id ? 'active' : 'text-dark iats-hover-bg'}"
                                t-on-click="() => this.selectJob(job.id)">
                            <div class="fw-bold fs-6"><t t-esc="job.name"/></div>
                            <small t-attf-class="#{state.activeJobId === job.id ? 'text-white-50' : 'text-muted'}"><t t-esc="job.no_of_recruitment"/> Target Recruits</small>
                        </button>
                    </t>
                </div>
            </aside>

            <!-- Main Content Area -->
            <main class="flex-grow-1 d-flex flex-column h-100 overflow-hidden bg-white">
                
                <!-- dynamic List View -->
                <t t-if="state.viewMode === 'list'">
                    <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                        <div>
                            <h2 class="h4 fw-bold m-0 text-dark">Ranked Candidates</h2>
                            <p class="text-muted m-0 small">Select 2 to 4 candidates to view their IATS Comparison Matrix.</p>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <span class="text-muted small me-2"><t t-esc="state.selectedAppIds.length"/> selected</span>
                            <button class="btn btn-outline-primary shadow-sm fw-bold border-2" t-att-disabled="state.selectedAppIds.length &lt; 2" t-on-click="() => this.toggleCompareMode()">
                                <i class="fa fa-balance-scale me-1"></i> Compare Matrix Sandbox
                            </button>
                        </div>
                    </div>

                    <div class="flex-grow-1 overflow-auto p-4 iats-animate-fade" style="background-color: #f1f5f9;">
                        <div class="row g-4 w-100 m-0">
                            <t t-foreach="state.applicants" t-as="app" t-key="app.id">
                                <div class="col-xxl-3 col-xl-4 col-md-6 px-2">
                                    <div class="card h-100 border-0 shadow-sm rounded-4 iats-matrix-col-hover position-relative bg-white" style="transition: all 0.2s; cursor: pointer;" t-attf-style="#{state.selectedAppIds.includes(app.id) ? 'box-shadow: 0 0 0 2px var(--o-brand-primary, #714B67) !important;' : ''}" t-on-click="() => this.toggleSelection(app.id)">
                                        
                                        <div class="position-absolute top-0 end-0 p-3 z-1">
                                            <input type="checkbox" class="form-check-input iats-checkbox-lg m-0 shadow-sm border-secondary" t-att-checked="state.selectedAppIds.includes(app.id)" t-on-click.stop="() => this.toggleSelection(app.id)"/>
                                        </div>

                                        <div class="card-body p-4 d-flex flex-column h-100" t-attf-style="#{state.selectedAppIds.includes(app.id) ? 'background-color: rgba(113, 75, 103, 0.03) !important;' : ''}">
                                            <div class="d-flex align-items-start gap-3 mb-4">
                                                <div class="iats-score-pill shadow-sm" style="flex-shrink: 0; width: 55px; height: 55px;" t-attf-class="#{this.getScoreColor(app.iats_score)}">
                                                    <t t-esc="Math.round(app.iats_score)"/>
                                                </div>
                                                <div class="overflow-hidden pe-4">
                                                    <h5 class="fw-bold m-0 text-dark text-truncate" t-att-title="app.partner_name || 'Unnamed'"><t t-esc="app.partner_name || 'Unnamed'"/></h5>
                                                    <span t-if="app.iats_recommendation === 'shortlist'" class="badge bg-success bg-opacity-25 text-success rounded-pill mt-2 border border-success">Shortlisted</span>
                                                    <span t-elif="app.iats_recommendation === 'review'" class="badge bg-warning bg-opacity-25 text-warning rounded-pill mt-2 border border-warning">Review</span>
                                                    <span t-elif="app.iats_recommendation === 'reject'" class="badge bg-danger bg-opacity-25 text-danger rounded-pill mt-2 border border-danger">Not a Fit</span>
                                                </div>
                                            </div>

                                            <div class="mb-4 flex-grow-1">
                                                <div class="small fw-bold text-muted mb-2 text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">AI Extracted Skills</div>
                                                <div class="d-flex flex-wrap gap-1">
                                                    <t t-if="app.iats_matched_skills">
                                                        <t t-foreach="app.iats_matched_skills.split(',').slice(0,4)" t-as="skill" t-key="skill">
                                                            <span class="badge bg-light text-dark border px-2 py-1 fw-bold" style="font-size:0.7rem;"><t t-esc="skill.trim()"/></span>
                                                        </t>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge bg-light text-muted border px-2 py-1 fw-normal" style="font-size:0.7rem;">None specifically parsed</span>
                                                    </t>
                                                </div>
                                            </div>

                                            <div class="mb-3 mt-auto">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="text-muted small fw-bold" style="font-size: 0.70rem;">Overall Match Score</span>
                                                    <span class="text-dark small fw-bold"><t t-esc="Math.round((app.iats_skill_score + app.iats_experience_score + app.iats_education_score) / 3)"/>%</span>
                                                </div>
                                                <div class="progress bg-light" style="height: 6px;">
                                                    <div class="progress-bar bg-primary opacity-50 rounded-pill" t-attf-style="width: #{(app.iats_skill_score + app.iats_experience_score + app.iats_education_score) / 3}%;"/>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center pt-3 border-top mt-3">
                                                <div class="small fw-bold text-secondary">
                                                    <i class="fa fa-briefcase text-primary opacity-50 me-1"></i> <t t-esc="Math.round(app.iats_experience_score)"/>% Exp Match
                                                </div>
                                                <button class="btn btn-sm btn-outline-secondary border shadow-sm px-3 rounded-pill fw-bold" style="transition: all 0.2s;" t-on-click.stop="() => this.openApplicant(app.id)">Full CV</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                            <t t-if="state.applicants.length === 0">
                                <div class="col-12 text-center py-5 text-muted">
                                    <i class="fa fa-folder-open mb-3 fa-3x opacity-25"></i><br/>
                                    No candidates have been processed by IATS for this position.
                                </div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- Comparison Matrix View -->
                <t t-if="state.viewMode === 'compare'">
                    <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                        <div class="d-flex align-items-center gap-3">
                            <button class="btn btn-sm btn-light border shadow-sm" t-on-click="() => this.toggleCompareMode()">
                                <i class="fa fa-arrow-left me-1"></i> Back to Ranked List
                            </button>
                            <h2 class="h5 fw-bold m-0 text-dark">Comparison Scorecard</h2>
                        </div>
                    </div>

                    <div class="flex-grow-1 overflow-auto bg-light p-4 iats-animate-fade">
                        <div class="d-flex h-100 overflow-x-auto pb-4 custom-scrollbar gap-4">
                            
                            <!-- Matrix Columns -->
                            <t t-foreach="this.selectedApplicantsData" t-as="app" t-key="app.id">
                                <div class="iats-matrix-col border rounded-4 flex-shrink-0 d-flex flex-column overflow-hidden">
                                    <!-- Header -->
                                    <div class="p-4 border-bottom text-center" style="background:#f8f9fc;">
                                        <div class="iats-score-pill mx-auto mb-3 shadow-sm" t-attf-class="#{this.getScoreColor(app.iats_score)}">
                                            <t t-esc="app.iats_score"/>
                                        </div>
                                        <h4 class="fw-bold m-0 text-truncate"><t t-esc="app.partner_name || 'Unknown'"/></h4>
                                        <span t-if="app.iats_recommendation === 'shortlist'" class="badge bg-success mt-2">Shortlisted</span>
                                        <span t-elif="app.iats_recommendation === 'review'" class="badge bg-warning mt-2">Review</span>
                                        <span t-elif="app.iats_recommendation === 'reject'" class="badge bg-danger mt-2">Reject</span>
                                    </div>
                                    
                                    <!-- Pillar Scores Details -->
                                    <div class="p-4 flex-grow-1 overflow-auto bg-white custom-scrollbar">

                                        <!-- New AI Fit Analysis Box -->
                                        <div class="mb-4">
                                            <h6 class="fw-bold small text-uppercase mb-2 text-dark">AI Fit Analysis</h6>
                                            <div class="p-2 bg-success bg-opacity-10 border border-success border-opacity-25 rounded-3 mb-2">
                                                <p class="text-success fw-bold m-0 mb-1" style="font-size:0.7rem; letter-spacing:0.5px;">MATCHED SKILLS</p>
                                                <div class="d-flex flex-wrap gap-1">
                                                    <t t-if="app.iats_matched_skills">
                                                        <t t-foreach="app.iats_matched_skills.split(',')" t-as="skill" t-key="skill">
                                                            <span class="badge bg-white text-success border border-success border-opacity-25 shadow-sm" style="font-size:0.7rem;"><t t-esc="skill.trim()"/></span>
                                                        </t>
                                                    </t>
                                                    <t t-else=""><span class="small text-muted fst-italic">None identified</span></t>
                                                </div>
                                            </div>
                                            
                                            <div class="p-2 bg-danger bg-opacity-10 border border-danger border-opacity-25 rounded-3">
                                                <p class="text-danger fw-bold m-0 mb-1" style="font-size:0.7rem; letter-spacing:0.5px;">MISSING SKILLS</p>
                                                <div class="d-flex flex-wrap gap-1">
                                                    <t t-if="app.iats_missing_skills">
                                                        <t t-foreach="app.iats_missing_skills.split(',')" t-as="mskill" t-key="mskill">
                                                            <span class="badge bg-white text-danger border border-danger border-opacity-25 shadow-sm" style="font-size:0.7rem;"><t t-esc="mskill.trim()"/></span>
                                                        </t>
                                                    </t>
                                                    <t t-elif="app.iats_skill_score &lt; 20"><span class="badge bg-white text-danger border border-danger border-opacity-25 shadow-sm" style="font-size:0.7rem;">Complete Profile Mismatch</span></t>
<t t-else=""><span class="small text-muted fst-italic">No critical misses</span></t>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Red flags -->
                                        <div class="mb-4">
                                            <h6 class="fw-bold small text-uppercase mb-2 text-dark">Red Flags &amp; Insights</h6>
                                            <div class="p-3 bg-warning bg-opacity-10 border border-warning border-opacity-50 rounded-3 text-dark small shadow-sm" style="line-height: 1.5;">
                                                <t t-if="app.iats_red_flags">
                                                    <t t-out="app.iats_red_flags"/>
                                                </t>
                                                <t t-elif="(app.iats_skill_score + app.iats_experience_score + app.iats_education_score) == 0">
                                                    <span class="text-danger fw-bold"><i class="fa fa-exclamation-triangle me-1"></i> Critical: Zero profile match or keyword stuffing detected. Resume ignored.</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted fst-italic"><i class="fa fa-check text-success me-1"></i> No immediate red flags detected.</span>
                                                </t>
                                            </div>
                                        </div>

                                        <hr class="opacity-10 my-4"/>

                                        <h6 class="fw-bold small text-uppercase mb-3 text-dark">Detailed Score Breakdown</h6>
                                        <!-- Skill -->
                                        <div class="mb-4">
                                            <div class="d-flex justify-content-between small fw-bold mb-1">
                                                <span>Skill Match</span>
                                                <span t-attf-class="#{app.iats_skill_score &gt; 70 ? 'text-success' : 'text-muted'}"><t t-esc="Math.round(app.iats_skill_score)"/>%</span>
                                            </div>
                                            <div class="progress progress-slim">
                                                <div t-attf-class="progress-bar #{this.getScoreColor(app.iats_skill_score)}" t-attf-style="width: #{app.iats_skill_score}%;"/>
                                            </div>
                                        </div>
                                        <!-- Experience -->
                                        <div class="mb-4">
                                            <div class="d-flex justify-content-between small fw-bold mb-1">
                                                <span>Experience Match</span>
                                                <span t-attf-class="#{app.iats_experience_score &gt; 70 ? 'text-success' : 'text-muted'}"><t t-esc="Math.round(app.iats_experience_score)"/>%</span>
                                            </div>
                                            <div class="progress progress-slim">
                                                <div t-attf-class="progress-bar #{this.getScoreColor(app.iats_experience_score)}" t-attf-style="width: #{app.iats_experience_score}%;"/>
                                            </div>
                                        </div>
                                        <!-- Education -->
                                        <div class="mb-4">
                                            <div class="d-flex justify-content-between small fw-bold mb-1">
                                                <span>Education Match</span>
                                                <span t-attf-class="#{app.iats_education_score &gt; 70 ? 'text-success' : 'text-muted'}"><t t-esc="Math.round(app.iats_education_score)"/>%</span>
                                            </div>
                                            <div class="progress progress-slim">
                                                <div t-attf-class="progress-bar #{this.getScoreColor(app.iats_education_score)}" t-attf-style="width: #{app.iats_education_score}%;"/>
                                            </div>
                                        </div>
                                        <!-- Keywords -->
                                        <div class="mb-4">
                                            <div class="d-flex justify-content-between small fw-bold mb-1">
                                                <span>Keyword Density</span>
                                                <span t-attf-class="#{app.iats_keyword_score &gt; 70 ? 'text-success' : 'text-muted'}"><t t-esc="Math.round(app.iats_keyword_score)"/>%</span>
                                            </div>
                                            <div class="progress progress-slim">
                                                <div t-attf-class="progress-bar #{this.getScoreColor(app.iats_keyword_score)}" t-attf-style="width: #{app.iats_keyword_score}%;"/>
                                            </div>
                                        </div>
                                        <!-- Summary Box -->
                                        <div class="mt-4 p-3 bg-light rounded-3 border small text-muted fst-italic" style="font-size:0.8rem; line-height: 1.4;">
                                            " <t t-esc="app.iats_match_summary || 'No AI summary generated for this parsed resume.'"/> "
                                        </div>
                                    </div>
                                    <div class="p-3 border-top text-center bg-white">
                                        <button class="btn btn-outline-primary btn-sm w-100" t-on-click="() => this.openApplicant(app.id)">Open Application</button>
                                    </div>
                                </div>
                            </t>
                            
                            <!-- Add more prompt -->
                            <t t-if="state.selectedAppIds.length &lt; 4">
                                <div class="iats-matrix-col border-dashed rounded-4 d-flex align-items-center justify-content-center flex-shrink-0" style="background:transparent; border: 2px dashed #cbd5e1; cursor:pointer;" t-on-click="() => this.toggleCompareMode()">
                                    <div class="text-center text-muted opacity-50">
                                        <i class="fa fa-plus-circle fa-2x mb-2"></i>
                                        <p class="m-0 fw-bold">Select more candidates</p>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>

            </main>
        </div>
    </t>
</templates>
