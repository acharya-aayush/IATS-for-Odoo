<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_job_form_iats" model="ir.ui.view">
        <field name="name">hr.job.form.iats</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.hr_job_survey"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_iats_high_match" type="object" class="oe_stat_button" icon="fa-trophy" groups="hr_recruitment.group_hr_recruitment_user">
                    <field name="iats_high_match_count" widget="statinfo" string="Top Applicants"/>
                </button>
                <button
                    name="action_open_iats_profile"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-crosshairs"
                    groups="hr_recruitment.group_hr_recruitment_user">
                    <field name="iats_profile_count" widget="statinfo" string="IATS Profiles"/>
                </button>
            </xpath>
            <xpath expr="//page[@name='job_description_page']" position="after">
                <page string="IATS Screening" name="iats_page" groups="hr_recruitment.group_hr_recruitment_user">
                    <group>
                        <group string="Metrics">
                            <field name="iats_profile_count" readonly="1"/>
                            <field name="iats_average_score" readonly="1"/>
                            <field name="iats_high_match_count" readonly="1"/>
                        </group>
                        <group string="Actions">
                            <button name="action_open_iats_profile" type="object" string="Configure Profile &amp; Run Screening" class="btn-primary" icon="fa-sliders"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
